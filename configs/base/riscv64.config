# riscv64 — RISC-V 64-bit base configuration for XanMod
#
# XanMod upstream does not ship RISC-V configs. This is a minimal starting
# point. RISC-V support in XanMod patches is largely untested; treat as
# experimental.

CONFIG_RISCV=y
CONFIG_64BIT=y
CONFIG_RISCV_ISA_C=y
CONFIG_RISCV_ISA_A=y
CONFIG_RISCV_ISA_F=y
CONFIG_RISCV_ISA_D=y

CONFIG_LOCALVERSION="-xanmod1"
CONFIG_LOCALVERSION_AUTO=n

CONFIG_CC_OPTIMIZE_FOR_PERFORMANCE=y

# SBI
# CONFIG_RISCV_SBI_V01 was removed in 6.2; SBI v0.2+ is the only supported
# interface in 6.x kernels. CONFIG_RISCV_SBI remains.
CONFIG_RISCV_SBI=y

# Scheduler
CONFIG_HZ_1000=y
CONFIG_HZ=1000
CONFIG_NO_HZ_FULL=y
