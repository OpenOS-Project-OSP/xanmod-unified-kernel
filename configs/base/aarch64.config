# aarch64 — ARM64 base configuration for XanMod
#
# XanMod upstream does not ship ARM64 configs; this is a starting point
# derived from common ARM64 distro configs with XanMod-compatible options.
# Test thoroughly on your specific SoC/board.

CONFIG_ARM64=y
CONFIG_64BIT=y

CONFIG_LOCALVERSION="-xanmod1"
CONFIG_LOCALVERSION_AUTO=n

CONFIG_CC_OPTIMIZE_FOR_PERFORMANCE=y

# ARM64 specific
CONFIG_ARM64_PAGE_SHIFT=12
CONFIG_ARM64_CONT_SHIFT=4
CONFIG_ARCH_MMAP_RND_BITS=18
CONFIG_ARCH_MMAP_RND_COMPAT_BITS=11

# Enable common ARM64 CPU errata workarounds
# Note: CONFIG_ARM64_ERRATUM_1024718 was removed in 6.1 (workaround folded in).
# The remaining errata symbols are present in 6.x.
CONFIG_ARM64_ERRATUM_843419=y
CONFIG_ARM64_ERRATUM_845719=y
CONFIG_ARM64_ERRATUM_1418040=y
CONFIG_ARM64_ERRATUM_1463225=y
CONFIG_ARM64_ERRATUM_1530923=y
CONFIG_ARM64_ERRATUM_1542419=y

# SVE / SIMD
CONFIG_ARM64_SVE=y

# Pointer authentication
CONFIG_ARM64_PTR_AUTH=y
CONFIG_ARM64_PTR_AUTH_KERNEL=y

# Memory tagging
CONFIG_ARM64_MTE=y

# Large system extensions
CONFIG_ARM64_LSE_ATOMICS=y

# Scheduler
CONFIG_HZ_1000=y
CONFIG_HZ=1000
CONFIG_NO_HZ_FULL=y
CONFIG_RCU_NOCB_CPU=y
