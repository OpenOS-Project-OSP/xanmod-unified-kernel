# hardware/steamdeck.config — Steam Deck (AMD Van Gogh APU) config fragment
#
# Targets the Steam Deck (LCD and OLED models) running a non-SteamOS distro
# on the AMD Van Gogh APU (Zen 2 CPU + RDNA 2 GPU, custom 4-core/8-thread).
#
# Applied when profile=steamdeck or EXTRA_CONFIG=configs/hardware/steamdeck.config.
#
# References:
#   - Valve's jupiter kernel: https://github.com/ValveSoftware/jupiter-hw-support
#   - AMD Van Gogh upstream patches: merged in 5.17-5.19

# ── AMD GPU (RDNA 2 / GFX10.3 / gfx1033) ────────────────────────────────────
CONFIG_DRM_AMDGPU=y
CONFIG_DRM_AMDGPU_SI=n
CONFIG_DRM_AMDGPU_CIK=n
CONFIG_DRM_AMDGPU_USERPTR=y
CONFIG_HSA_AMD=y
CONFIG_HSA_AMD_SVM=y

# ── AMD audio (ACP5x — Van Gogh specific) ────────────────────────────────────
CONFIG_SND_SOC_AMD_ACP5x=m
CONFIG_SND_SOC_AMD_VANGOGH_MACH=m
CONFIG_SND_SOC_MAX98388=m

# ── AMD CPU / power management ────────────────────────────────────────────────
CONFIG_X86_AMD_PSTATE=y
CONFIG_X86_AMD_PSTATE_UT=n
# Van Gogh uses amd-pstate in passive mode by default
CONFIG_X86_AMD_PSTATE_DEFAULT_MODE=2

# ── Input / HID (Steam Deck controller, gyro, touchpads) ─────────────────────
CONFIG_HID_STEAM=m
CONFIG_JOYSTICK_XPAD=m
CONFIG_INPUT_UINPUT=m
# IIO for gyroscope (BMI160 on LCD, BMI323 on OLED)
CONFIG_IIO=y
CONFIG_IIO_BUFFER=y
CONFIG_IIO_TRIGGERED_BUFFER=y
CONFIG_BMI160_I2C=m
CONFIG_BMI160_SPI=m
# OLED model gyro
CONFIG_BMI323_I2C=m

# ── Display ───────────────────────────────────────────────────────────────────
CONFIG_DRM=y
CONFIG_DRM_PANEL_ORIENTATION_QUIRKS=y
# eDP panel (internal display)
CONFIG_DRM_PANEL_BOE_TV101WUM_NL6=m
CONFIG_DRM_PANEL_SIMPLE=m
# Backlight
CONFIG_BACKLIGHT_CLASS_DEVICE=y
CONFIG_BACKLIGHT_GENERIC=m

# ── Storage (NVMe + SD card) ──────────────────────────────────────────────────
CONFIG_BLK_DEV_NVME=y
CONFIG_MMC=y
CONFIG_MMC_SDHCI=y
CONFIG_MMC_SDHCI_PCI=y
CONFIG_MMC_SDHCI_ACPI=y

# ── WiFi (AMD RZ608 / MT7921K) ────────────────────────────────────────────────
CONFIG_MT7921E=m
CONFIG_MT7921S=m
CONFIG_MT76_CONNAC_LIB=m

# ── Bluetooth (MT7921K) ───────────────────────────────────────────────────────
CONFIG_BT=m
CONFIG_BT_HCIBTUSB=m
CONFIG_BT_HCIBTUSB_MTK=y

# ── USB-C / Thunderbolt ───────────────────────────────────────────────────────
CONFIG_USB_TYPEC=y
CONFIG_USB_TYPEC_UCSI=m
CONFIG_UCSI_ACPI=m
CONFIG_TYPEC_DP_ALTMODE=m

# ── Suspend / resume ──────────────────────────────────────────────────────────
# s2idle (S0ix) is the only working suspend mode on Van Gogh
CONFIG_ACPI_EC_DEBUGFS=y
CONFIG_PM_AUTOSLEEP=y
CONFIG_PM_WAKELOCKS=y

# ── Thermal ───────────────────────────────────────────────────────────────────
CONFIG_THERMAL=y
CONFIG_AMD_THERMAL=y
CONFIG_THERMAL_GOV_POWER_ALLOCATOR=y

# ── Misc ──────────────────────────────────────────────────────────────────────
# Haptic feedback motor
CONFIG_INPUT_FF_MEMLESS=m
# Battery / charging
CONFIG_BATTERY_BQ27XXX=m
CONFIG_CHARGER_BQ25890=m
