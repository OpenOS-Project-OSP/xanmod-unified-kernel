# features/btrfs-dwarfs.config — BTRFS+DwarFS hybrid filesystem framework
#
# Enables the btrfs_dwarfs kernel module from btrfs-dwarfs-framework.
# Requires BTRFS and FUSE to be enabled (both are set in the base configs).
#
# Dependencies satisfied by base configs:
#   CONFIG_BTRFS_FS=m (or y)
#   CONFIG_FUSE_FS=m (or y)
#   CONFIG_NET=y

CONFIG_BTRFS_DWARFS=m
# CONFIG_BTRFS_DWARFS_DEBUG is not set
